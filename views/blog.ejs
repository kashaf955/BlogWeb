<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head') %>
    <title>Blog Post</title>
</head>
<body>
    <%- include('./partials/nav') %>
    <div class="container article-page">
        <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
            <h1 class="mb-0 article-title"><%= blog.title %></h1>
            <% const isOwner = locals.user && blog.createdBy && String(locals.user._id) === String(blog.createdBy._id); %>
            <% if (isOwner) { %>
            <button
                type="button"
                class="btn btn-danger"
                id="deleteBlogBtn"
                data-blog-id="<%= blog._id %>"
            >
                Delete Blog
            </button>
            <% } %>
        </div>
        <% if (blog.coverImageURL) { %>
        <img class="article-cover" src="<%= blog.coverImageURL %>" width="500" height="300" alt="Blog Cover Image">
        <% } %>
        <pre><%= blog.body %></pre>

    <div class="author-box container mt-3">
        <% if (blog.createdBy) { %>
        <img src="<%= blog.createdBy.profileImageURL || '/images/download.jpg' %>" width="50" height="50" alt="User Profile Image">
         <%= blog.createdBy.fullName %>
        <% } else { %>
         Unknown author
        <% } %>
    </div>

    <div class="comments-panel container mt-3">
        <h3>Comments</h3>

        <% if (comments && comments.length) { %>
          <ul class="list-unstyled mb-4">
            <% comments.forEach(comment => { %>
              <li class="mb-3 pb-3 border-bottom">
                <div class="d-flex align-items-center gap-2 mb-1">
                  <img
                    src="<%= comment.createdBy?.profileImageURL || '/images/download.jpg' %>"
                    width="32"
                    height="32"
                    alt="Commenter"
                    style="border-radius: 50%; object-fit: cover;"
                  >
                  <strong><%= comment.createdBy?.fullName || 'Unknown user' %></strong>
                </div>
                <p class="mb-0"><%= comment.body %></p>
              </li>
            <% }) %>
          </ul>
        <% } else { %>
          <p class="text-muted">No comments yet.</p>
        <% } %>

        <% if (locals.user) { %>
          <form action="/blogs/comments/<%= blog._id %>" method="POST">
            <div class="mb-3">
                <label for="comment" class="form-label">Add a comment</label>
                <input 
                type="text" 
                class="form-control" 
                id="comment" 
                name="comment"
                aria-describedby="commentHelp">
            </div>
            <button type="submit" class="btn btn-primary">Submit</button>
        </form>
          <% } else { %>
          <p class="text-muted">Sign in to add a comment.</p>
          <% } %>
    </div>

    <%- include('./partials/scripts') %>
    <script>
      const deleteBtn = document.getElementById('deleteBlogBtn');
      if (deleteBtn) {
        deleteBtn.addEventListener('click', async () => {
          const blogId = deleteBtn.dataset.blogId;
          if (!confirm('Are you sure you want to delete this blog?')) return;

          try {
            const response = await fetch('/blogs/' + blogId, { method: 'DELETE' });
            if (response.ok || response.redirected) {
              window.location.href = '/';
              return;
            }
            const message = await response.text();
            alert(message || 'Failed to delete blog.');
          } catch (error) {
            alert('Failed to delete blog.');
          }
        });
      }
    </script>

</div>
</body> 
</html>
