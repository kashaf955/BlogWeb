<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head') %>
    <title>Home Page</title>
</head>
<body>
    <%- include('./partials/nav') %>
    <div class = "container mt-3 row row-cols-3">
        <% blogs.forEach(blog => { %>
            <div class = "col mt-4">
            <div class="card col" style="width: 18rem;">
  <img src="<%= blog.coverImageURL || '/images/download.jpg' %>" class="card-img-top" alt="<%= blog.title %>">
  <div class="card-body">
    <h5 class="card-title"><%= blog.title %></h5>
    <a href="/blogs/<%= blog._id %>" class="btn btn-primary">View Blog</a>
  </div>
  </div>
</div>
         
        <% }) %>
    </div>
    <%- include('./partials/scripts') %>
    </body>
</html>