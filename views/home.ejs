<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head') %>
    <title>Home Page</title>
</head>
<body>
    <%- include('./partials/nav') %>

    <header class="page-hero container">
      <p class="page-eyebrow">Blogweb</p>
      <h1 class="page-title">Stories worth reading</h1>
      <p class="page-lead">Browse posts from the community.</p>
    </header>

    <div class="container blog-grid-wrap">
      <% if (!blogs || !blogs.length) { %>
        <div class="empty-state">
          <h2>No blogs yet</h2>
          <p class="text-muted">Be the first to publish something.</p>
        </div>
      <% } else { %>
        <div class="blog-grid">
          <% blogs.forEach(blog => { %>
            <div class="blog-card">
              <img src="<%= blog.coverImageURL || '/images/download.jpg' %>" class="card-img-top" alt="<%= blog.title %>">
              <div class="blog-card-body">
                <h5 class="card-title"><%= blog.title %></h5>
                <div class="d-flex flex-wrap gap-2">
                  <a href="/blogs/<%= blog._id %>" class="btn btn-primary">View Blog</a>
                  <% const canEdit = locals.user && blog.createdBy && String(locals.user._id) === String(blog.createdBy._id || blog.createdBy); %>
                  <% if (canEdit) { %>
                  <a href="/blogs/<%= blog._id %>/edit" class="btn btn-outline-secondary">Edit</a>
                  <% } %>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <%- include('./partials/scripts') %>
</body>
</html>
